{
  "private": true,
  "name": "tgui-workspace",
  "version": "6.0.0",
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "tgui:analyze": "rspack build --env RSDOCTOR=1",
    "tgui:bench": "rspack --env TGUI_BENCH=1 && node packages/tgui-bench/index.js",
    "tgui:build": "rspack build",
    "tgui:dev": "node --experimental-modules packages/tgui-dev-server/index.js",
    "tgui:lint": "eslint packages --ext .js,.cjs,.ts,.tsx",
    "tgui:lint-fix": "eslint --fix packages --ext .js,.cjs,.ts,.jsx,.tsx",
    "tgui:prettier": "prettier --check .",
    "tgui:prettier-fix": "prettier --write .",
    "tgui:test": "vitest",
    "tgui:test-simple": "CI=true vitest",
    "tgui:test-ci": "CI=true vitest",
    "tgui:tsc": "tsc",
    "tgui:normalize-svgs": "node normalize-svgs.mjs"
  },
  "dependencies": {
    "@rspack/cli": "^2.0.4",
    "@rspack/core": "^2.0.4",
    "@rspack/dev-server": "^2.0.1",
    "@typescript-eslint/parser": "^8.59.4",
    "@typescript-eslint/utils": "^8.59.4",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "sass-embedded": "^1.100.0",
    "sass-loader": "^17.0.0",
    "typescript": "6.0.3",
    "url-loader": "^4.1.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@rsdoctor/rspack-plugin": "^1.5.11",
    "@types/node": "^25.9.1",
    "@types/webpack-env": "^1.18.8",
    "@types/wicg-file-system-access": "^2023.10.7",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "vitest": "^4.1.7"
  }
}
